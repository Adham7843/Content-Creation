# Content-Creation Environment
# Copy to .env and fill in your keys

## Media Tools
FFMPEG_PATH=ffmpeg
PLAYWRIGHT_BROWSERS_PATH=

## AI / LLM
OPENCODE_CLI_PATH=opencode
DEEPSEEK_API_KEY=
PREFERRED_MODEL=opencode/deepseek-v4-flash-free

## External Tool Paths
OPENSOURCE_CLIPPING_PATH=F:/Notes/Tools/opensource-clipping
BRAINROTBOT_PATH=

## Output
CONTENT_OUTPUT_DIR=./output
